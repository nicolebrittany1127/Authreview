{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": null,
  "functions": {
    "api/analyze.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/analyze",
      "dest": "/api/analyze.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
